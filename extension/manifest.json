{
  "manifest_version": 3,
  "name": "Term PTT Custom Theme",
  "version": "0.1.0",
  "description": "在 term.ptt.cc 預覽並套用終端機配色，可選擇載入自訂 style/webfont。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "scripting"],
  "host_permissions": ["https://term.ptt.cc/*"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Term PTT Custom Theme"
  },
  "content_scripts": [
    {
      "matches": ["https://term.ptt.cc/*"],
      "css": ["assets/color.css"],
      "js": ["ptt-colors.js", "ptt-webfont-tags.js", "content.js"],
      "run_at": "document_start"
    }
  ]
}
